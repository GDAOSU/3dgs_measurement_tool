# Environment variables for the 3DGS Measurement Tool
# Copy this file to .env.local and fill in your values.
# These variables are OPTIONAL. The application will work with the default models without them.

# --- AWS S3 Configuration (for "Custom S3 Model" feature) ---
# Required if you want to load models from your own public S3 bucket.
# Your bucket must have a CORS policy allowing GET requests from your domain.

# The AWS region where your S3 bucket is located.
VITE_AWS_REGION=

# The name of your S3 bucket.
VITE_S3_BUCKET=

# Cesium Ion Token (optional, for Cesium base maps)
# Get token from https://ion.cesiumjs.com
VITE_CESIUM_ION_TOKEN=
