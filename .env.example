# Example environment variables for the 3DGS Measurement Tool.
# Copy this file to .env.local and fill in the values as needed.

# --- Deployment ---
# The base path of the application when deployed. Defaults to '/'.
# For GitHub Pages, this should be your repository name (e.g., /3dgs_measurement_tool/).
VITE_BASE_PATH=/

# --- Optional: For the "Custom S3 Model" feature ---
# Your public AWS S3 bucket name.
VITE_S3_BUCKET=
# The AWS region where your bucket is located (e.g., us-east-1).
VITE_AWS_REGION=